# ==============================================================================
# CELCOM ERP PRO - SYSTEM ENVIRONMENT SETTINGS
# ==============================================================================

# Node Environment Settings
NODE_ENV=development
PORT=3000

# 1. Database Connection (PostgreSQL)
# Configured for Prisma ORM connection. Replace placeholders with real credentials.
DATABASE_URL="postgresql://postgres:postgres_secure_password@localhost:5432/celcom_erp?schema=public"

# 2. Authentication & JWT Tokens
# Secret keys must be long, high-entropy cryptographic strings in production.
JWT_ACCESS_SECRET="generate_a_cryptographically_secure_string_at_least_32_chars_long"
JWT_REFRESH_SECRET="generate_another_cryptographically_secure_string_64_chars_long"

# Token Expiry Settings
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# 3. KRA PIN & TAX Configuration (Kenya Revenue Authority Integration)
KRA_VAT_RATE=0.16
KRA_WH_VAT_RATE=0.02
HOUSING_LEVY_RATE=0.015

# 4. Mail Transporter (SMTP) Settings (for Alerts, Invoices & Payroll Notifications)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
SMTP_FROM="no-reply@celcomnetworks.co.ke"

# 5. External ISP Radius & PPPoE Integration (Nairobi Headend API Link)
RADIUS_API_URL="https://radius-api.celcomnetworks.co.ke"
RADIUS_API_KEY="secure_radius_tunnel_key"
